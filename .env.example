# Team 12 — 240 2nd Avenue (CriticalAsset staging)
# Copy to .env and fill from your credential sheet. Never commit .env.

CA_API_URL=https://2402ndave.stg.criticalasset.com/api
CA_CONSOLE_URL=https://2402ndave.stg.criticalasset.com/
CA_CLIENT_ID=ca_your_client_id_here
CA_CLIENT_SECRET=your_client_secret_here
CA_SCOPES=workorders.read assets.read locations.read

# Human console fallback when M2M credentials fail (server-side scripts only)
CA_CONSOLE_EMAIL=your_team_email@2402ndave.com
CA_CONSOLE_PASSWORD=
CA_SUBDOMAIN=2402ndave
